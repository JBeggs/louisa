# Honey & Related (Template 2) — copy to .env.local for local overrides.

# API: local dev defaults to http://localhost:8000/api when unset
# NEXT_PUBLIC_API_URL=https://your-api.example.com/api

# Tenant slug (X-Company-Slug). Create via django-crm /admin/setup.
NEXT_PUBLIC_COMPANY_SLUG=honey
NEXT_PUBLIC_API_URL=https://3pillars.pythonanywhere.com/api
# Optional: canonical site URL for metadata / OG
# NEXT_PUBLIC_SITE_URL=https://your-honey-store.example.com
