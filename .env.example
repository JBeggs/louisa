# Louisa (Template 9) — copy to .env.local for local overrides.

# NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_API_URL=https://your-api.example.com/api

# Tenant slug (X-Company-Slug). Provision company in django-crm.
NEXT_PUBLIC_COMPANY_SLUG=louisa

# Optional: canonical site URL for metadata / OG (no trailing slash)
# NEXT_PUBLIC_SITE_URL=https://your-louisa-site.example.com

# Optional: OG image proxy User-Agent
# OG_PROXY_USER_AGENT=Louisa-OgProxy/1.0
